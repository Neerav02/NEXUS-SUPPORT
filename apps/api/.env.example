# ── NEXUS SUPPORT API — Environment Variables ──

NODE_ENV=development
PORT=8080

# Database
DATABASE_URL=postgresql://nexus:nexus_dev_password@postgres:5432/nexus_support

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change_me_to_a_long_random_secret_minimum_64_characters_for_security
JWT_EXPIRES_IN=8h
CUSTOMER_JWT_EXPIRES_IN=4h

# mediasoup
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=49999
MEDIASOUP_WORKERS=2

# Storage (Cloudflare R2 or MinIO)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nexus-support
R2_PUBLIC_URL=

# Reconnect Grace Windows
AGENT_RECONNECT_TIMEOUT_SECONDS=120
CUSTOMER_RECONNECT_TIMEOUT_SECONDS=30

# FFmpeg
FFMPEG_PATH=/usr/bin/ffmpeg

# CORS
CORS_ORIGINS=http://localhost:5173

# File Uploads
MAX_FILE_SIZE_MB=20
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Metrics
METRICS_SECRET=change_me_to_a_random_metrics_secret
